{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Weather Data Schema",
  "description": "Schema for triathlon race weather data",
  "required": ["date", "sunrise", "sunset", "minTemp", "maxTemp", "hourly"],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Race date in ISO 8601 format (YYYY-MM-DD)"
    },
    "sunrise": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}$",
      "description": "Sunrise time in HH:MM format"
    },
    "sunset": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}$",
      "description": "Sunset time in HH:MM format"
    },
    "minTemp": {
      "type": "number",
      "description": "Minimum temperature in Celsius"
    },
    "maxTemp": {
      "type": "number",
      "description": "Maximum temperature in Celsius"
    },
    "hourly": {
      "type": "array",
      "description": "Hourly weather data",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "time",
          "weatherCode",
          "temp",
          "humidity",
          "dewPoint",
          "pressure",
          "pressureChange",
          "windDirectionCode",
          "windSpeed",
          "visibility",
          "discomfortIndex"
        ],
        "properties": {
          "time": {
            "type": "string",
            "description": "Hour of the day"
          },
          "weatherCode": {
            "type": "string",
            "enum": [
              "CLEAR",
              "PARTLY_CLOUDY",
              "CLOUDY",
              "RAIN",
              "SHOWERS",
              "HEAVY_RAIN",
              "THUNDER",
              "STORM",
              "FOG",
              "UNKNOWN"
            ],
            "description": "Machine-readable weather condition"
          },
          "temp": {
            "type": "number",
            "description": "Temperature in Celsius"
          },
          "humidity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Humidity percentage"
          },
          "dewPoint": {
            "type": "number",
            "description": "Dew point temperature in Celsius"
          },
          "pressure": {
            "type": "number",
            "description": "Atmospheric pressure in hPa"
          },
          "pressureChange": {
            "type": "string",
            "description": "Pressure change with + or - prefix, or empty string"
          },
          "windDirectionCode": {
            "type": "string",
            "enum": [
              "N",
              "NNE",
              "NE",
              "ENE",
              "E",
              "ESE",
              "SE",
              "SSE",
              "S",
              "SSW",
              "SW",
              "WSW",
              "W",
              "WNW",
              "NW",
              "NNW",
              "CALM",
              "UNKNOWN"
            ],
            "description": "16-point compass wind direction code"
          },
          "windSpeed": {
            "type": "number",
            "minimum": 0,
            "description": "Wind speed in m/s"
          },
          "visibility": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0,
                "description": "Visibility in km"
              },
              {
                "type": "string",
                "enum": ["---"],
                "description": "No data available"
              }
            ]
          },
          "discomfortIndex": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 100,
                "description": "Discomfort index"
              },
              {
                "type": "string",
                "enum": ["---"],
                "description": "No data available"
              }
            ]
          }
        }
      }
    }
  }
}
